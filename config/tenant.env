# =============================================================================
# Freiwillig — Tenant Configuration
# =============================================================================
# Fill in all required fields marked with [REQUIRED].
# Optional fields have sensible defaults.
#
# After editing:
#   ./install.sh --config tenant      (first install)
#   ./install.sh --reconfigure        (update existing)
# =============================================================================

# ── Organisation ─────────────────────────────────────────────────────────────

# [REQUIRED] Full organisation name (shown in UI and emails)
ORG_NAME="Freunde Waldorf Freiwilligendienste"

# [REQUIRED] URL-safe slug — lowercase, no spaces, only letters/numbers/hyphens
# Used in internal routing, Valkey stream names, Zitadel org ID
ORG_SLUG="freunde-waldorf"

# [REQUIRED] Domain where the app will be accessible
# Local:      localhost
# Production: freiwillig.deine-ngo.de
DOMAIN="localhost"

# [OPTIONAL] Logo URL (shown in emails and login screen)
ORG_LOGO_URL=""

# [OPTIONAL] Website of the organisation
ORG_WEBSITE="https://www.freunde-waldorf.de"

# [OPTIONAL] Primary contact phone (shown on login screen)
ORG_PHONE="+49 721 20111-0"

# ── Language & Region ─────────────────────────────────────────────────────────

# [OPTIONAL] UI language: de | en | fr | es
LANGUAGE="de"

# [OPTIONAL] Timezone (used for emails, reports, scheduling)
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE="Europe/Berlin"

# [OPTIONAL] Country code (ISO 3166-1 alpha-2)
COUNTRY="DE"

# ── Admin Account ─────────────────────────────────────────────────────────────
# This account is created as the first coordinator.
# Password is auto-generated and sent to ADMIN_EMAIL via Zitadel.

# [REQUIRED]
ADMIN_EMAIL="koordination@freunde-waldorf.de"

# [REQUIRED]
ADMIN_FIRST_NAME="Maria"

# [REQUIRED]
ADMIN_LAST_NAME="Mustermann"

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave as mailpit for local dev — Mailpit catches all outgoing mail.
# Set to your real SMTP server for production.

# [OPTIONAL — defaults to Mailpit for dev]
SMTP_HOST="mailpit"
SMTP_PORT="1025"
SMTP_FROM="noreply@freunde-waldorf.de"
SMTP_TLS="false"

# Production example (e.g. Brevo/Postmark/your own Postfix):
# SMTP_HOST="smtp.brevo.com"
# SMTP_PORT="587"
# SMTP_FROM="noreply@freunde-waldorf.de"
# SMTP_TLS="true"
# SMTP_USER="your_brevo_login"
# SMTP_PASSWORD="your_brevo_password"

# ── Features (Pro Plan) ───────────────────────────────────────────────────────
# These are only active if your license includes Pro.
# Leave as-is if you're on Core plan.

# [OPTIONAL] Enable monthly check-in automation (Celery cron)
FEATURE_CHECKIN_AUTOMATION="true"

# [OPTIONAL] Enable Rocket.Chat integration
FEATURE_ROCKETCHAT="false"
ROCKETCHAT_URL=""
ROCKETCHAT_ADMIN_USER=""
ROCKETCHAT_ADMIN_PASSWORD=""

# [OPTIONAL] Max volunteers per organisation (0 = unlimited)
MAX_VOLUNTEERS="0"

# [OPTIONAL] Max placement sites per organisation (0 = unlimited)
MAX_SITES="0"

# ── Seeding Options ───────────────────────────────────────────────────────────

# [OPTIONAL] What to do if a seed record already exists:
#   skip    — leave existing data untouched (safe for re-runs)
#   update  — update changed fields
#   replace — delete and recreate (destructive)
SEED_ON_CONFLICT="skip"

# [OPTIONAL] Create example programme and site for demo/testing
SEED_CREATE_DEMO="false"
